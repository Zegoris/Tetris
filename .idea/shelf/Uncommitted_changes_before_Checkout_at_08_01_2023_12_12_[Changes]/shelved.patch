aminesW, self.tetraminesH = 5, 5\r\n        self.empty = 'o'\r\n        self.gm = game_mode\r\n        self.tetramines = {'S': [['ooooo',  # Game tetramines\r\n                                  'ooooo',\r\n                                  'ooxxo',\r\n                                  'oxxoo',\r\n                                  'ooooo'],\r\n                                 ['ooooo',\r\n                                  'ooxoo',\r\n                                  'ooxxo',\r\n                                  'oooxo',\r\n                                  'ooooo']],\r\n                           'Z': [['ooooo',\r\n                                  'ooooo',\r\n                                  'oxxoo',\r\n                                  'ooxxo',\r\n                                  'ooooo'],\r\n                                 ['ooooo',\r\n                                  'ooxoo',\r\n                                  'oxxoo',\r\n                                  'oxooo',\r\n                                  'ooooo']],\r\n                           'J': [['ooooo',\r\n                                  'oxooo',\r\n                                  'oxxxo',\r\n                                  'ooooo',\r\n                                  'ooooo'],\r\n                                 ['ooooo',\r\n                                  'ooxxo',\r\n                                  'ooxoo',\r\n                                  'ooxoo',\r\n                                  'ooooo'],\r\n                                 ['ooooo',\r\n                                  'ooooo',\r\n                                  'oxxxo',\r\n                                  'oooxo',\r\n                                  'ooooo'],\r\n                                 ['ooooo',\r\n                                  'ooxoo',\r\n                                  'ooxoo',\r\n                                  'oxxoo',\r\n                                  'ooooo']],\r\n                           'L': [['